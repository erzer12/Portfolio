# ─── Supabase ──────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API

# Public anon key — safe to expose (used in browser client)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Service role key — NEVER expose to browser (server actions only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Admin Auth ────────────────────────────────────────────────
# Choose any strong secret. This is your CMS password.
ADMIN_ACCESS_CODE=your-secret-code-here

# ─── Email (optional — for contact form) ───────────────────────
# RESEND_API_KEY=your-resend-key-here
# EMAIL_FROM=onboarding@resend.dev
# EMAIL_TO=harshilp1234@gmail.com
